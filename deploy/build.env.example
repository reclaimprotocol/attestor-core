# Copy to deploy/build.env (gitignored) and fill in.
#
# Required:
PROJECT_ID=your-gcp-project
DOMAIN=attestor.example.com
ACME_EMAIL=ops@example.com

# Optional overrides (defaults shown in comments):
# REGISTRY=gcr.io/${PROJECT_ID}
# ZONE=asia-south2-a
# INSTANCE=attestor-prod
# MACHINE_TYPE=n2d-standard-2
# SERVICE_ACCOUNT=tee-attestor-sa@${PROJECT_ID}.iam.gserviceaccount.com
# STATIC_IP_NAME=attestor-prod-ip
# FIREWALL_RULE=allow-attestor
# NETWORK_TAG=attestor
